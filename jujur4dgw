<script>
// List nama market
const markets = [
    "PASARAN TOGEL",
    "TOTO SGP",
    "TOTO HK",
    "SYDNEY",
    "POOLS NIGHT",
    "POOLS DAY",
    "SINGAPORE",
    "CAIRO",
    "SWISS",
    "TAIWAN",
    "QATAR",
    "HONGKONG LOTTO",
    "SYDNEY LOTTO",
    "TOTOMACAU 0000",
    "TOTOMACAU 1300",
    "TOTOMACAU 1600",
    "TOTOMACAU 1900",
    "TOTOMACAU 2200",
    "TOTOMACAU 2300 ",
    "JAPAN",
    "TAIWAN",
    "KOREA",
    "CAMBODIA",
    "CHINA",
    "THAILAND",
];

// Render market ke top bar
const marketBar = document.getElementById("marketBar");

markets.forEach((market, index) => {
    const item = document.createElement("div");
    item.classList.add("market-item");

    if(index === 0) item.classList.add("active");

    item.innerText = market;

    item.addEventListener("click", () => {
        document.querySelectorAll(".market-item").forEach(el => el.classList.remove("active"));
        item.classList.add("active");
    });

    marketBar.appendChild(item);
});
</script>

